-  knownDivisibility[0] = gcd(lbLattice->getValue().getDivisibility(0),
-                             stepLattice->getValue().getDivisibility(0));
-  auto inductionVar =
-      AxisInfo(knownContiguity, knownDivisibility, knownConstancy);
-  (void)argLattices[0]->join(inductionVar);
-}
